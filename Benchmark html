<!DOCTYPE html>

<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>OpenCLAW-P2P v4 × IGAS — Unified Stability Benchmark</title>
<link href="https://fonts.googleapis.com/css2?family=DM+Mono:ital,wght@0,300;0,400;0,500;1,400&family=Syne:wght@400;600;700;800&family=Space+Grotesk:wght@300;400;500&display=swap" rel="stylesheet">
<style>
  :root {
    --bg: #050810;
    --surface: #0c1120;
    --surface2: #111827;
    --border: rgba(99,179,255,0.12);
    --tau: #4af0c8;
    --tau-dim: rgba(74,240,200,0.18);
    --lyap: #f0a84a;
    --lyap-dim: rgba(240,168,74,0.18);
    --pov: #b06cf0;
    --pov-dim: rgba(176,108,240,0.18);
    --mift: #f06c8a;
    --mift-dim: rgba(240,108,138,0.18);
    --text: #e2eaf8;
    --muted: #6b7fa3;
    --grid: rgba(99,179,255,0.06);
    --pass: #4af0a0;
    --fail: #f06c6c;
    --warn: #f0c84a;
  }

- { margin:0; padding:0; box-sizing:border-box; }

body {
background: var(–bg);
color: var(–text);
font-family: ‘Space Grotesk’, sans-serif;
font-size: 14px;
line-height: 1.6;
min-height: 100vh;
overflow-x: hidden;
}

/* Grid background */
body::before {
content:’’;
position: fixed;
inset: 0;
background-image:
linear-gradient(var(–grid) 1px, transparent 1px),
linear-gradient(90deg, var(–grid) 1px, transparent 1px);
background-size: 48px 48px;
pointer-events: none;
z-index: 0;
}

/* Ambient glow */
body::after {
content:’’;
position: fixed;
top: -30%;
left: -20%;
width: 80%;
height: 80%;
background: radial-gradient(ellipse, rgba(74,240,200,0.04) 0%, transparent 70%);
pointer-events: none;
z-index: 0;
}

.wrapper {
position: relative;
z-index: 1;
max-width: 1340px;
margin: 0 auto;
padding: 0 24px 80px;
}

/* ── HEADER ─────────────────────────── */
header {
padding: 52px 0 36px;
border-bottom: 1px solid var(–border);
margin-bottom: 40px;
}

.badge-row {
display: flex;
gap: 10px;
margin-bottom: 20px;
flex-wrap: wrap;
}

.badge {
font-family: ‘DM Mono’, monospace;
font-size: 10px;
letter-spacing: 0.12em;
text-transform: uppercase;
padding: 4px 10px;
border-radius: 4px;
border: 1px solid;
}

.badge-tau   { color: var(–tau);  border-color: var(–tau);  background: var(–tau-dim); }
.badge-lyap  { color: var(–lyap); border-color: var(–lyap); background: var(–lyap-dim); }
.badge-pov   { color: var(–pov);  border-color: var(–pov);  background: var(–pov-dim); }
.badge-mift  { color: var(–mift); border-color: var(–mift); background: var(–mift-dim); }

h1 {
font-family: ‘Syne’, sans-serif;
font-size: clamp(22px, 3vw, 36px);
font-weight: 800;
letter-spacing: -0.02em;
line-height: 1.15;
margin-bottom: 10px;
}

h1 span.accent { color: var(–tau); }
h1 span.cross { color: var(–muted); font-weight: 400; }

.subtitle {
color: var(–muted);
font-size: 13px;
font-family: ‘DM Mono’, monospace;
max-width: 700px;
}

.meta-row {
display: flex;
gap: 32px;
margin-top: 20px;
flex-wrap: wrap;
}

.meta-item {
font-family: ‘DM Mono’, monospace;
font-size: 11px;
color: var(–muted);
}

.meta-item strong {
color: var(–text);
display: block;
font-size: 12px;
}

/* ── SECTION TITLES ─────────────────── */
.section-title {
font-family: ‘Syne’, sans-serif;
font-size: 11px;
font-weight: 700;
letter-spacing: 0.18em;
text-transform: uppercase;
color: var(–muted);
margin-bottom: 16px;
padding-bottom: 8px;
border-bottom: 1px solid var(–border);
display: flex;
align-items: center;
gap: 10px;
}

.section-title::before {
content: ‘’;
width: 3px;
height: 14px;
border-radius: 2px;
}

.section-title.tau-line::before { background: var(–tau); }
.section-title.lyap-line::before { background: var(–lyap); }
.section-title.pov-line::before { background: var(–pov); }
.section-title.mift-line::before { background: var(–mift); }
.section-title.combined-line::before { background: linear-gradient(180deg, var(–tau), var(–lyap)); }

/* ── CARDS ──────────────────────────── */
.card {
background: var(–surface);
border: 1px solid var(–border);
border-radius: 10px;
padding: 22px 24px;
position: relative;
overflow: hidden;
}

.card::before {
content:’’;
position: absolute;
top: 0; left: 0; right: 0;
height: 2px;
}

.card.tau-card::before   { background: linear-gradient(90deg, var(–tau), transparent); }
.card.lyap-card::before  { background: linear-gradient(90deg, var(–lyap), transparent); }
.card.pov-card::before   { background: linear-gradient(90deg, var(–pov), transparent); }
.card.mift-card::before  { background: linear-gradient(90deg, var(–mift), transparent); }
.card.combined-card::before { background: linear-gradient(90deg, var(–tau), var(–lyap)); }

/* ── KPI GRID ───────────────────────── */
.kpi-grid {
display: grid;
grid-template-columns: repeat(auto-fit, minmax(190px, 1fr));
gap: 14px;
margin-bottom: 36px;
}

.kpi {
background: var(–surface);
border: 1px solid var(–border);
border-radius: 10px;
padding: 18px 20px;
position: relative;
overflow: hidden;
animation: fadeUp 0.5s ease both;
}

.kpi:nth-child(1) { animation-delay: 0.05s; }
.kpi:nth-child(2) { animation-delay: 0.10s; }
.kpi:nth-child(3) { animation-delay: 0.15s; }
.kpi:nth-child(4) { animation-delay: 0.20s; }
.kpi:nth-child(5) { animation-delay: 0.25s; }
.kpi:nth-child(6) { animation-delay: 0.30s; }
.kpi:nth-child(7) { animation-delay: 0.35s; }
.kpi:nth-child(8) { animation-delay: 0.40s; }

@keyframes fadeUp {
from { opacity:0; transform: translateY(12px); }
to   { opacity:1; transform: translateY(0); }
}

.kpi-label {
font-family: ‘DM Mono’, monospace;
font-size: 10px;
letter-spacing: 0.1em;
text-transform: uppercase;
color: var(–muted);
margin-bottom: 8px;
}

.kpi-value {
font-family: ‘Syne’, sans-serif;
font-size: 26px;
font-weight: 800;
line-height: 1;
margin-bottom: 4px;
}

.kpi-sub {
font-size: 11px;
color: var(–muted);
font-family: ‘DM Mono’, monospace;
}

.kpi-bar {
position: absolute;
bottom: 0; left: 0;
height: 2px;
border-radius: 0 2px 0 0;
transition: width 1.5s cubic-bezier(0.16,1,0.3,1);
}

/* ── TWO-COL LAYOUT ─────────────────── */
.two-col {
display: grid;
grid-template-columns: 1fr 1fr;
gap: 20px;
margin-bottom: 28px;
}

.three-col {
display: grid;
grid-template-columns: 1fr 1fr 1fr;
gap: 20px;
margin-bottom: 28px;
}

@media (max-width: 900px) {
.two-col, .three-col { grid-template-columns: 1fr; }
}

/* ── CHART CANVAS ───────────────────── */
.chart-wrap {
position: relative;
height: 200px;
margin-top: 16px;
}

canvas {
display: block;
width: 100% !important;
}

/* ── DATA TABLE ─────────────────────── */
table {
width: 100%;
border-collapse: collapse;
font-family: ‘DM Mono’, monospace;
font-size: 12px;
}

th {
text-align: left;
padding: 10px 14px;
color: var(–muted);
font-size: 10px;
letter-spacing: 0.1em;
text-transform: uppercase;
border-bottom: 1px solid var(–border);
}

td {
padding: 10px 14px;
border-bottom: 1px solid rgba(99,179,255,0.06);
color: var(–text);
vertical-align: middle;
}

tr:last-child td { border-bottom: none; }
tr:hover td { background: rgba(74,240,200,0.03); }

.pill {
display: inline-block;
padding: 2px 8px;
border-radius: 4px;
font-size: 10px;
font-weight: 500;
letter-spacing: 0.05em;
}

.pill-pass  { background: rgba(74,240,160,0.15); color: var(–pass); }
.pill-fail  { background: rgba(240,108,108,0.15); color: var(–fail); }
.pill-warn  { background: rgba(240,200,74,0.15);  color: var(–warn); }

/* ── PROGRESS BARS ───────────────────── */
.pbar-row {
display: flex;
align-items: center;
gap: 10px;
margin-bottom: 10px;
}

.pbar-label {
font-family: ‘DM Mono’, monospace;
font-size: 11px;
color: var(–muted);
width: 140px;
flex-shrink: 0;
}

.pbar-track {
flex: 1;
height: 6px;
background: rgba(99,179,255,0.1);
border-radius: 3px;
overflow: hidden;
}

.pbar-fill {
height: 100%;
border-radius: 3px;
transition: width 1.8s cubic-bezier(0.16,1,0.3,1);
width: 0;
}

.pbar-val {
font-family: ‘DM Mono’, monospace;
font-size: 11px;
width: 42px;
text-align: right;
color: var(–text);
}

/* ── FORMULA BOX ─────────────────────── */
.formula-box {
background: var(–surface2);
border: 1px solid var(–border);
border-radius: 8px;
padding: 14px 18px;
font-family: ‘DM Mono’, monospace;
font-size: 12px;
color: var(–tau);
margin: 12px 0;
letter-spacing: 0.02em;
line-height: 1.8;
}

.formula-box .comment {
color: var(–muted);
font-size: 11px;
}

/* ── VERDICT BOX ─────────────────────── */
.verdict {
border-radius: 10px;
padding: 20px 24px;
margin-bottom: 28px;
border: 1px solid;
display: flex;
align-items: flex-start;
gap: 16px;
}

.verdict.pass { border-color: rgba(74,240,160,0.3); background: rgba(74,240,160,0.06); }
.verdict.warn { border-color: rgba(240,200,74,0.3);  background: rgba(240,200,74,0.06); }

.verdict-icon {
font-size: 24px;
line-height: 1;
flex-shrink: 0;
margin-top: 2px;
}

.verdict-title {
font-family: ‘Syne’, sans-serif;
font-weight: 700;
font-size: 15px;
margin-bottom: 4px;
}

.verdict-body {
font-size: 13px;
color: var(–muted);
line-height: 1.6;
}

/* ── HEATMAP ─────────────────────────── */
.heatmap {
display: grid;
grid-template-columns: 140px repeat(4, 1fr);
gap: 3px;
font-family: ‘DM Mono’, monospace;
font-size: 10px;
margin-top: 12px;
}

.hm-cell {
padding: 8px 6px;
border-radius: 4px;
text-align: center;
font-size: 10px;
}

.hm-header {
background: transparent;
color: var(–muted);
font-size: 9px;
letter-spacing: 0.08em;
display: flex;
align-items: center;
justify-content: center;
padding: 4px;
}

.hm-label {
background: transparent;
color: var(–muted);
text-align: left;
display: flex;
align-items: center;
font-size: 10px;
}

/* ── SCATTER ─────────────────────────── */
.scatter-wrap {
position: relative;
height: 240px;
margin-top: 12px;
}

/* ── TABS ────────────────────────────── */
.tabs {
display: flex;
gap: 4px;
margin-bottom: 16px;
border-bottom: 1px solid var(–border);
}

.tab-btn {
padding: 8px 16px;
background: none;
border: none;
border-bottom: 2px solid transparent;
color: var(–muted);
font-family: ‘DM Mono’, monospace;
font-size: 11px;
cursor: pointer;
letter-spacing: 0.06em;
text-transform: uppercase;
transition: all 0.2s;
margin-bottom: -1px;
}

.tab-btn:hover { color: var(–text); }
.tab-btn.active { color: var(–tau); border-bottom-color: var(–tau); }

.tab-panel { display: none; }
.tab-panel.active { display: block; }

/* ── SPARKLINE ───────────────────────── */
.sparkline-row {
display: flex;
align-items: center;
gap: 12px;
margin-bottom: 8px;
}

.spark-label {
font-family: ‘DM Mono’, monospace;
font-size: 10px;
color: var(–muted);
width: 100px;
flex-shrink: 0;
}

.spark-val {
font-family: ‘DM Mono’, monospace;
font-size: 11px;
color: var(–text);
width: 40px;
flex-shrink: 0;
text-align: right;
}

svg.spark { overflow: visible; }

/* ── ANNOTATION ──────────────────────── */
.annotation {
font-family: ‘DM Mono’, monospace;
font-size: 10px;
color: var(–muted);
padding: 8px 14px;
background: var(–surface2);
border-radius: 6px;
margin-top: 10px;
border-left: 2px solid var(–tau);
}

.section-group {
margin-bottom: 48px;
}

/* ── DIFF TABLE ───────────────────── */
.diff-positive { color: var(–pass); }
.diff-negative { color: var(–fail); }

</style>
</head>
