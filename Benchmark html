      const bg = `rgba(${r},${g},${b},0.22)`;
      const col = `rgb(${r},${g},${b})`;
      hm.innerHTML += `<div class="hm-cell" style="background:${bg};color:${col};font-family:'DM Mono',monospace;font-size:11px;">${v}%</div>`;
    });
  });
})();

// ── ABLATION CHARTS ───────────────────────────────────
(function(){
  const configs = [
    'No τ, No MIFT,\nNo IGAS',
    'τ only',
    'τ+MIFT',
    'MIFT+IGAS\n(no τ)',
    'τ+IGAS\n(no MIFT)',
    'τ+MIFT+IGAS\n(full)',
  ];

  function makeBar(id, data, label, color){
    const ctx = document.getElementById(id).getContext('2d');
    new Chart(ctx,{
      type:'bar',
      data:{
        labels: configs,
        datasets:[{ label, data, backgroundColor: data.map((_,i)=> i===5 ? color : color.replace('0.18','0.10')), borderColor:color.replace('0.18','1'), borderWidth:1.5 }]
      },
      options:{...baseOpts, plugins:{legend:{display:false}}, scales:{
        x:{...baseOpts.scales.x, ticks:{...baseOpts.scales.x.ticks, maxRotation:0, font:{family:'DM Mono',size:9}}},
        y:{...baseOpts.scales.y, max:100}
      }}
    });
  }

  makeBar('ablVeChart',   [38,71,86,52,81,86], 'Verification Efficiency (%)', C.tauA);
  makeBar('ablFairChart', [51,18,12,44,11, 8], 'Gini Coefficient (lower=better)', C.povA);
  makeBar('ablDriftChart',[47,22,9, 31, 7, 9], 'Drift Events at 20% Adv.',      C.miftA);
})();

// ── TABS ──────────────────────────────────────────────
document.querySelectorAll('.tab-btn').forEach(btn=>{
  btn.addEventListener('click',()=>{
    const tab = btn.dataset.tab;
    document.querySelectorAll('.tab-btn').forEach(b=>b.classList.remove('active'));
    document.querySelectorAll('.tab-panel').forEach(p=>p.classList.remove('active'));
    btn.classList.add('active');
    document.getElementById(tab).classList.add('active');
    // trigger resize so chart renders correctly
    window.dispatchEvent(new Event('resize'));
  });
});

// trigger bar animations on scroll
const observer = new IntersectionObserver((entries)=>{
  entries.forEach(e=>{
    if(e.isIntersecting){
      e.target.querySelectorAll('[data-w]').forEach(el=>{
        el.style.width = el.dataset.w + '%';
      });
    }
  });
},{threshold:0.1});

document.querySelectorAll('.kpi-grid, #giniBars, #latencyBars').forEach(el=>observer.observe(el));
</script>

