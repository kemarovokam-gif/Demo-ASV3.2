  <script>
    // ─── COLOUR TOKENS ───────────────────────────────────────────────────────
    const C = {
      bg: "#07080a", panel: "#0d0f12", border: "#1c2028",
      green: "#00ff9d", blue: "#00b4ff", amber: "#ffb800", red: "#ff3c3c",
      dim: "#2a3040", text: "#c8d0de", muted: "#4a5568", hyper: "#bf7fff"
